# ─── Server ───────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Google Gemini AI ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com

# ─── Google Sheets ────────────────────────────────────
# Your Google Sheet ID (from the URL: spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Service Account JSON key file (relative to backend/)
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account-key.json

# ─── Retell AI ────────────────────────────────────────
RETELL_API_KEY=your_retell_api_key_here
# Agent IDs per topic (get from Retell dashboard)
RETELL_AGENT_ID_GOOGLE_ADS=your_google_ads_agent_id_here
RETELL_AGENT_ID_META_ADS=your_meta_ads_agent_id_here
RETELL_AGENT_ID_SEO=your_seo_agent_id_here
RETELL_AGENT_ID_DIGITAL_MARKETING=your_digital_marketing_agent_id_here
RETELL_AGENT_ID_HR=your_hr_agent_id_here
